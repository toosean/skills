#!/usr/bin/env python3
import argparse
import json
import mimetypes
import os
import sys
import tempfile
import time
import uuid
from pathlib import Path
from urllib import error, parse, request


DEFAULT_BASE_URL = "https://api.tu-zi.com"
DEFAULT_MODEL = "gemini-3-pro-image-preview-async"
#DEFAULT_MODEL = "gpt-image-2"
DEFAULT_SIZE = "1:1"
DEFAULT_INITIAL_WAIT = 10.0
DEFAULT_POLL_INTERVAL = 10.0
DEFAULT_TIMEOUT = 300.0


def build_parser():
    parser = argparse.ArgumentParser(
        description="Submit a Tu-Zi async image generation job and wait for completion.",
    )
    parser.add_argument("--prompt", required=True, help="Image prompt.")
    parser.add_argument("--model", default=DEFAULT_MODEL, help="Model name.")
    parser.add_argument("--size", default=DEFAULT_SIZE, help="Output size ratio.")
    parser.add_argument(
        "--initial-wait",
        type=float,
        default=DEFAULT_INITIAL_WAIT,
        help="Seconds to wait before the first poll.",
    )
    parser.add_argument(
        "--poll-interval",
        type=float,
        default=DEFAULT_POLL_INTERVAL,
        help="Seconds between polls after the first poll.",
    )
    parser.add_argument(
        "--timeout",
        type=float,
        default=DEFAULT_TIMEOUT,
        help="Maximum total seconds to wait for completion.",
    )
    parser.add_argument(
        "--output-dir",
        help="Directory where the generated image will be saved. Defaults to a temp folder.",
    )
    parser.add_argument(
        "--file-name",
        help="Optional output file name. Extension is inferred when possible.",
    )
    parser.add_argument(
        "--no-download",
        action="store_true",
        help="Return the image URL without downloading the file.",
    )
    parser.add_argument(
        "--base-url",
        default=DEFAULT_BASE_URL,
        help=argparse.SUPPRESS,
    )
    return parser


def require_api_key():
    api_key = os.environ.get("TU_ZI_API_KEY")
    if api_key:
        return api_key
    raise RuntimeError("Missing TU_ZI_API_KEY environment variable.")


def encode_multipart_form(fields):
    boundary = f"----CodexTuZi{uuid.uuid4().hex}"
    chunks = []
    for name, value in fields.items():
        chunks.append(f"--{boundary}\r\n".encode("utf-8"))
        chunks.append(
            f'Content-Disposition: form-data; name="{name}"\r\n\r\n'.encode("utf-8")
        )
        chunks.append(str(value).encode("utf-8"))
        chunks.append(b"\r\n")
    chunks.append(f"--{boundary}--\r\n".encode("utf-8"))
    return boundary, b"".join(chunks)


def decode_body(body, headers):
    charset = headers.get_content_charset() or "utf-8"
    return body.decode(charset, errors="replace")


def http_json(url, *, method, headers, data=None, timeout=60.0):
    req = request.Request(url, data=data, headers=headers, method=method)
    try:
        with request.urlopen(req, timeout=timeout) as resp:
            raw = resp.read()
            text = decode_body(raw, resp.headers)
    except error.HTTPError as exc:
        raw = exc.read()
        text = raw.decode("utf-8", errors="replace")
        raise RuntimeError(f"HTTP {exc.code} for {url}: {text}") from exc
    except error.URLError as exc:
        raise RuntimeError(f"Request failed for {url}: {exc.reason}") from exc

    try:
        return json.loads(text)
    except json.JSONDecodeError as exc:
        raise RuntimeError(f"Non-JSON response from {url}: {text}") from exc


def submit_job(base_url, api_key, prompt, model, size):
    boundary, body = encode_multipart_form(
        {
            "model": model,
            "prompt": prompt,
            "size": size,
        }
    )
    return http_json(
        f"{base_url.rstrip('/')}/v1/videos",
        method="POST",
        headers={
            "Authorization": f"Bearer {api_key}",
            "Content-Type": f"multipart/form-data; boundary={boundary}",
        },
        data=body,
    )


def fetch_job(base_url, api_key, job_id):
    return http_json(
        f"{base_url.rstrip('/')}/v1/videos/{job_id}",
        method="GET",
        headers={
            "Authorization": f"Bearer {api_key}",
        },
    )


def wait_for_completion(
    base_url,
    api_key,
    job_id,
    *,
    initial_wait,
    poll_interval,
    timeout,
):
    deadline = time.monotonic() + timeout
    last_observation = None
    if initial_wait > 0:
        print(
            f"Job {job_id} submitted, waiting {initial_wait:.1f}s before first poll...",
            file=sys.stderr,
        )
        time.sleep(initial_wait)

    while True:
        if time.monotonic() >= deadline:
            message = f"Timed out while waiting for job {job_id} to complete."
            if last_observation:
                message += f" Last observation: {last_observation}"
            raise TimeoutError(message)

        try:
            payload = fetch_job(base_url, api_key, job_id)
        except Exception as exc:
            last_observation = f"poll error: {exc}"
            print(f"Job {job_id} poll error: {exc}", file=sys.stderr)
            time.sleep(poll_interval)
            continue

        status = payload.get("status")
        print(f"Job {job_id} status: {status}", file=sys.stderr)

        if status == "completed":
            return payload

        if status in {"queued", "in_progress"}:
            last_observation = f"status={status}"
            time.sleep(poll_interval)
            continue

        last_observation = (
            "unexpected payload: "
            + json.dumps(payload, ensure_ascii=False, separators=(",", ":"))
        )
        print(f"Job {job_id} unexpected status, retrying: {last_observation}", file=sys.stderr)
        time.sleep(poll_interval)


def guess_extension(image_url, content_type):
    normalized_type = (content_type or "").split(";", 1)[0].strip().lower()
    if normalized_type.startswith("image/"):
        guessed = mimetypes.guess_extension(normalized_type)
        if guessed:
            return guessed

    url_path = parse.urlparse(image_url).path
    ext = Path(url_path).suffix
    if ext:
        return ext.lower()
    return ".png"


def resolve_output_path(output_dir, file_name, image_url, headers, job_id):
    target_dir = (
        Path(output_dir) if output_dir else Path(tempfile.gettempdir()) / "tu-zi-nano"
    )
    target_dir.mkdir(parents=True, exist_ok=True)

    if file_name:
        candidate = Path(file_name)
        if candidate.suffix:
            return target_dir / candidate.name
        ext = guess_extension(image_url, headers.get("Content-Type"))
        return target_dir / f"{candidate.name}{ext}"

    ext = guess_extension(image_url, headers.get("Content-Type"))
    return target_dir / f"{job_id}{ext}"


def download_image(image_url, output_dir=None, file_name=None, timeout=60.0, job_id="image"):
    req = request.Request(image_url, method="GET")
    try:
        with request.urlopen(req, timeout=timeout) as resp:
            data = resp.read()
            output_path = resolve_output_path(
                output_dir,
                file_name,
                image_url,
                resp.headers,
                job_id,
            )
    except error.HTTPError as exc:
        raw = exc.read().decode("utf-8", errors="replace")
        raise RuntimeError(f"Failed to download image: HTTP {exc.code}: {raw}") from exc
    except error.URLError as exc:
        raise RuntimeError(f"Failed to download image: {exc.reason}") from exc

    output_path.write_bytes(data)
    return output_path.resolve()


def main():
    parser = build_parser()
    args = parser.parse_args()

    try:
        api_key = require_api_key()
        submission = submit_job(
            args.base_url,
            api_key,
            args.prompt,
            args.model,
            args.size,
        )
        job_id = submission.get("id")
        if not job_id:
            raise RuntimeError(
                "Submission response did not include an id: "
                + json.dumps(submission, ensure_ascii=False, separators=(",", ":"))
            )

        completed = wait_for_completion(
            args.base_url,
            api_key,
            job_id,
            initial_wait=args.initial_wait,
            poll_interval=args.poll_interval,
            timeout=args.timeout,
        )
        image_url = completed.get("video_url")
        if not image_url:
            raise RuntimeError(
                "Completed response did not include video_url: "
                + json.dumps(completed, ensure_ascii=False, separators=(",", ":"))
            )

        result = {
            "id": job_id,
            "status": completed.get("status", "completed"),
            "image_url": image_url,
            "prompt": args.prompt,
            "size": args.size,
            "model": args.model,
        }

        if not args.no_download:
            saved_path = download_image(
                image_url,
                output_dir=args.output_dir,
                file_name=args.file_name,
                job_id=job_id,
            )
            result["saved_path"] = str(saved_path)

        print(json.dumps(result, ensure_ascii=False))
        return 0
    except Exception as exc:
        print(str(exc), file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
